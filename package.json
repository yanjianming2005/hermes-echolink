{
  "name": "hermes-echolink",
  "version": "0.1.1",
  "private": false,
  "description": "A lightweight WebSocket chat server for Hermes Agent with modern Web UI",
  "type": "module",
  "license": "MIT",
  "author": "EchoLink Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanjianming2005/hermes-echolink.git"
  },
  "keywords": [
    "hermes",
    "agent",
    "chat",
    "websocket",
    "im",
    "messaging",
    "real-time"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@types/ws": "^8.5.13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
